#!/usr/bin/env bash
#
# MediaControl - 媒体播放控制脚本
# 支持 playerctl 和 mpc 两种后端

set -euo pipefail
IFS=$'\n\t'

readonly COVER="/tmp/cover.png"
readonly FALLBACK_COVER="${HOME}/.config/eww/assets/fallback.png"
readonly MPD_DIR="${HOME}/Music"

readonly CONTROL="${CONTROL:-MPD}"
readonly OPTION="${1:-}"
readonly PARAM="${2:-}"

init_cover() {
    mkdir -p "$(dirname "${COVER}")" 2>/dev/null || true
}

get_metadata() {
    local key="$1"
    playerctl --player="${CONTROL}" metadata --format "{{${key}}}" 2>/dev/null || echo ""
}

get_status() {
    playerctl --player="${CONTROL}" status 2>/dev/null || echo "Stopped"
}

mpd_current() {
    mpc current -f "%${1}%" 2>/dev/null || echo ""
}

mpd_status() {
    mpc status 2>/dev/null | head -2 | tail -1 | cut -c2-7 || echo ""
}

do_next() {
    case "${CONTROL}" in
        MPD) mpc -q next ;;
        *)   playerctl --player="${CONTROL}" next ;;
    esac
}

do_previous() {
    case "${CONTROL}" in
        MPD) mpc -q prev ;;
        *)   playerctl --player="${CONTROL}" previous ;;
    esac
}

do_toggle() {
    case "${CONTROL}" in
        MPD) mpc -q toggle ;;
        *)   playerctl --player="${CONTROL}" play-pause ;;
    esac
}

do_stop() {
    case "${CONTROL}" in
        MPD) mpc -q stop ;;
        *)   playerctl --player="${CONTROL}" stop ;;
    esac
}

get_title() {
    local title
    case "${CONTROL}" in
        MPD) title=$(mpd_current title) ;;
        *)   title=$(get_metadata title) ;;
    esac
    echo "${title:-Nothing Playing}"
}

get_artist() {
    local artist
    case "${CONTROL}" in
        MPD) artist=$(mpd_current artist) ;;
        *)   artist=$(get_metadata artist) ;;
    esac
    echo "${artist:-Offline}"
}

get_album() {
    local album
    case "${CONTROL}" in
        MPD) album=$(mpd_current album) ;;
        *)   album=$(get_metadata album) ;;
    esac
    echo "${album:-Album}"
}

get_status_icon() {
    local status icon
    case "${CONTROL}" in
        MPD) status=$(mpd_status) ;;
        *)   status=$(get_status) ;;
    esac

    case "${status}" in
        *playing*|*playin*) icon="" ;;
        *paused*)            icon="" ;;
        *)                   icon="" ;;
    esac
    echo "${icon}"
}

get_position() {
    local time
    case "${CONTROL}" in
        MPD) time=$(mpc status %currenttime% 2>/dev/null) ;;
        *)   time=$(playerctl --player="${CONTROL}" position --format "{{ duration(position) }}" 2>/dev/null) ;;
    esac
    echo "${time:-0:00}"
}

get_position_sec() {
    local time
    case "${CONTROL}" in
        MPD) time=$(mpc status %currenttime% 2>/dev/null | awk -F: '{print ($1 * 60) + $2}') ;;
        *)   time=$(playerctl --player="${CONTROL}" position 2>/dev/null | sed 's/..\{6\}$//') ;;
    esac
    echo "${time:-0}"
}

get_length() {
    local length
    case "${CONTROL}" in
        MPD) length=$(mpc status %totaltime% 2>/dev/null) ;;
        *)   length=$(playerctl --player="${CONTROL}" metadata --format "{{ duration(mpris:length) }}" 2>/dev/null) ;;
    esac
    echo "${length:-0:00}"
}

get_length_sec() {
    local length
    case "${CONTROL}" in
        MPD) length=$(mpc status %totaltime% 2>/dev/null | awk -F: '{print ($1 * 60) + $2}') ;;
        *)   length=$(playerctl --player="${CONTROL}" metadata mpris:length 2>/dev/null | sed 's/.\{6\}$//') ;;
    esac
    echo "${length:-0}"
}

get_percent() {
    local perc
    case "${CONTROL}" in
        MPD) perc=$(mpc status %percenttime% 2>/dev/null) ;;
        *)   perc="0" ;;
    esac
    echo "${perc:-0}"
}

get_playlist_pos() {
    local pos all
    case "${CONTROL}" in
        MPD)
            pos=$(mpc status %songpos% 2>/dev/null)
            all=$(mpc status %length% 2>/dev/null)
            echo "${pos:-0}/${all:-0}"
            ;;
        *)
            pos=$(playerctl --player="${CONTROL}" metadata xesam:trackNumber 2>/dev/null)
            echo "${pos:-0}"
            ;;
    esac
}

get_shuffle() {
    local shuffle
    case "${CONTROL}" in
        MPD)
            shuffle=$(mpc status 2>/dev/null | sed -n '3s/.*random: \([^ ]*\).*/\1/p' | sed 's/.*/\u&/')
            ;;
        *)
            shuffle=$(playerctl --player="${CONTROL}" shuffle 2>/dev/null)
            ;;
    esac
    echo "${shuffle:-Off}"
}

do_shuffle() {
    case "${CONTROL}" in
        MPD)
            case "${PARAM}" in
                toggle) mpc random ;;
                on)     mpc random on ;;
                off)    mpc random off ;;
            esac
            ;;
        *)
            playerctl --player="${CONTROL}" shuffle "${PARAM}" 2>/dev/null || true
            ;;
    esac
    get_shuffle
}

get_loop() {
    local loop
    case "${CONTROL}" in
        MPD)
            loop=$(mpc status 2>/dev/null | sed -n '3s/.*repeat: \([^ ]*\).*/\1/p' | sed 's/.*/\u&/')
            ;;
        *)
            loop=$(playerctl --player="${CONTROL}" loop 2>/dev/null)
            ;;
    esac
    echo "${loop:-Off}"
}

do_loop() {
    case "${CONTROL}" in
        MPD)
            case "${PARAM}" in
                none)     mpc repeat ;;
                playlist) mpc repeat ;;
                track)    mpc repeat ;;
            esac
            ;;
        *)
            playerctl --player="${CONTROL}" loop "${PARAM}" 2>/dev/null || true
            ;;
    esac
    get_loop
}

get_cover() {
    case "${CONTROL}" in
        MPD)
            local file
            file=$(mpc current -f %file% 2>/dev/null)
            if [[ -n "${file}" ]]; then
                ffmpeg -i "${MPD_DIR}/${file}" "${COVER}" -y 2>/dev/null || cp "${FALLBACK_COVER}" "${COVER}"
            else
                cp "${FALLBACK_COVER}" "${COVER}"
            fi
            ;;
        *)
            local art_url
            art_url=$(playerctl --player="${CONTROL}" metadata mpris:artUrl 2>/dev/null)
            if [[ -n "${art_url}" ]]; then
                art_url="${art_url//open.spotify.com/i.scdn.co}"
                curl -s "${art_url}" --output "${COVER}" 2>/dev/null || cp "${FALLBACK_COVER}" "${COVER}"
            else
                cp "${FALLBACK_COVER}" "${COVER}"
            fi
            ;;
    esac
    echo "${COVER}"
}

show_cover() {
    get_cover | xargs feh 2>/dev/null || true
}

get_json() {
    local icon status
    icon=$(get_status_icon)
    status=$(get_status)
    echo "{\"text\":\"${icon} $(get_artist)-$(get_title)\", \"class\":\"custom-player\",\"alt\":\"${CONTROL}\"}"
}

show_lyrics() {
    local win_id
    win_id=$(niri msg --json windows 2>/dev/null | jaq -r '.[] | select(.title=="Lyric").id' 2>/dev/null) || return
    if [[ -z "${win_id}" ]]; then
        alacritty -T "Lyrics" -e lyrics-next &
    fi
}

show_help() {
    cat <<EOF
Usage:
  media [Options]

Options:
  --previous      previous song
  --next          next song
  --toggle        toggle between play-pause song
  --stop          stop song
  --title         shows title of current song
  --album         shows album of current song
  --artist        shows artist of current song
  --status        music status
  --statusicon    music status icons
  --cover         saves cover and shows location
  --showcover     opens cover using feh
  --position      shows current time of song
  --positions     shows current time in seconds
  --length        shows length of song
  --lengths       shows length in seconds
  --percent       shows percent song
  --playlist      shows playlist position
  --shuffle       shuffle control
  --loop          loop control
  --lyrics        show lyrics window
  --json          show json status
  --help          show this help
EOF
}

main() {
    init_cover

    case "${OPTION}" in
        --next)          do_next ;;
        --previous)      do_previous ;;
        --toggle)        do_toggle ;;
        --stop)          do_stop ;;
        --title)         get_title ;;
        --artist)        get_artist ;;
        --album)         get_album ;;
        --status)        get_status ;;
        --statusicon)    get_status_icon ;;
        --player)        echo "${CONTROL}" ;;
        --cover)         get_cover ;;
        --showcover)     show_cover ;;
        --position)      get_position ;;
        --positions)     get_position_sec ;;
        --length)        get_length ;;
        --lengths)       get_length_sec ;;
        --percent)       get_percent ;;
        --playlist)      get_playlist_pos ;;
        --shuffle)       do_shuffle ;;
        --loop)          do_loop ;;
        --lyrics)        show_lyrics ;;
        --json)          get_json ;;
        --help|-h)      show_help ;;
        *)               show_help ;;
    esac
}

main "$@"
