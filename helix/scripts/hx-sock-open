#!/usr/bin/env bash
#
# https://github.com/erasin/helix/tree/local-socket-listening
# 
# hx-sock-open - 通过 socket 发送命令给 helix 打开文件
#
# 用法:
#   hx-sock-open <file>[:<line>[:<col>]]
#   hx-sock-open <project> <file>[:<line>[:<col>]]
#
# 示例:
#   hx-sock-open README.md
#   hx-sock-open README.md:10
#   hx-sock-open README.md:10:5
#   hx-sock-open /path/to/project README.md
#   hx-sock-open /path/to/project README.md:10:5

set -e

TRUSTED_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/helix/trusted_workspaces"
HELIX_SOCK_DIR=".helix"
HELIX_SOCK_NAME="helix.sock"

find_socket() {
    local dir="$1"
    local sock="$dir/$HELIX_SOCK_DIR/$HELIX_SOCK_NAME"
    if [[ -S "$sock" ]]; then
        echo "$sock"
        return 0
    fi
    return 1
}

find_workspace() {
    local target="$1"
    local cur="$target"

    while [[ "$cur" != "/" && "$cur" != "." ]]; do
        if find_socket "$cur" 2>/dev/null; then
            return 0
        fi
        cur="$(dirname "$cur")"
    done

    if find_socket "$target" 2>/dev/null; then
        return 0
    fi

    return 1
}

build_open_cmd() {
    local file="$1"
    local line="${2:-}"
    local col="${3:-}"

    local cmd=":open $file"
    if [[ -n "$line" ]]; then
        cmd="$cmd:$line"
        if [[ -n "$col" ]]; then
            cmd="$cmd:$col"
        fi
    fi

    echo "$cmd"
}

parse_file_arg() {
    local arg="$1"
    local file="${arg%%:*}"
    local rest="${arg#*:}"
    local line=""
    local col=""

    if [[ "$rest" != "$file" ]]; then
        if [[ "$rest" == *:* ]]; then
            line="${rest%%:*}"
            col="${rest#*:}"
        else
            line="$rest"
        fi
    fi

    echo "$file|$line|$col"
}

usage() {
    cat <<EOF
用法: hx-sock-open <file>[:<line>[:<col>]]
      hx-sock-open <project> <file>[:<line>[:<col>]]

通过 Unix socket 向 helix 发送命令打开文件。

参数:
  <file>[:<line>[:<col>]]  要打开的文件，可选指定行号和列号
  <project>                项目路径（会检查是否在 trusted_workspaces 中）

示例:
  hx-sock-open README.md
  hx-sock-open README.md:10
  hx-sock-open README.md:10:5
  hx-sock-open /path/to/project README.md
  hx-sock-open /path/to/project README.md:10:5
EOF
}

main() {
    local socket=""

    if [[ $# -eq 0 ]]; then
        usage
        exit 1
    fi

    if [[ $# -eq 1 ]]; then
        local parsed
        parsed=$(parse_file_arg "$1")
        local file="${parsed%%|*}"
        local line="${parsed#*|}"; line="${line%|*}"
        local col="${parsed##*|}"

        local dir
        dir=$(pwd)

        if ! find_workspace "$dir" >/dev/null 2>&1; then
            echo "错误: 当前目录 $dir 不在 trusted_workspaces 中，且没有找到 helix socket" >&2
            exit 1
        fi

        socket=$(find_workspace "$dir")
        local cmd
        cmd=$(build_open_cmd "$file" "$line" "$col")

        printf '%s' "$cmd" | socat - UNIX-CONNECT:"$socket"
        echo "已发送: $cmd"

    elif [[ $# -eq 2 ]]; then
        local project="$1"
        local file_arg="$2"

        local parsed
        parsed=$(parse_file_arg "$file_arg")
        local file="${parsed%%|*}"
        local line="${parsed#*|}"; line="${line%|*}"
        local col="${parsed##*|}"

        if [[ ! -d "$project" ]]; then
            echo "错误: 项目目录不存在: $project" >&2
            exit 1
        fi

        if [[ -f "$TRUSTED_FILE" ]]; then
            if ! grep -qF "$project" "$TRUSTED_FILE" 2>/dev/null; then
                echo "警告: $project 不在 trusted_workspaces 中" >&2
            fi
        fi

        if ! find_workspace "$project" >/dev/null 2>&1; then
            echo "错误: 项目 $project 中没有找到 helix socket" >&2
            exit 1
        fi

        socket=$(find_workspace "$project")

        local full_path=""
        if [[ -f "$project/$file" ]]; then
            full_path="$file"
        elif [[ -f "$file" ]]; then
            full_path="$file"
        else
            full_path="$project/$file"
        fi

        local cmd
        cmd=$(build_open_cmd "$full_path" "$line" "$col")

        printf '%s' "$cmd" | socat - UNIX-CONNECT:"$socket"
        echo "已发送: $cmd"

    else
        usage
        exit 1
    fi
}

main "$@"
