#!/bin/bash

# Workspace script for Niri / Hyprland / Sway
# Usage: Workspace <command> [args]

case "$1" in
    current)
        # 获取当前工作区编号
        if command -v niri &>/dev/null; then
            niri msg --format json focused-workspace | jaq -r '.idx'
        elif command -v hyprctl &>/dev/null; then
            hyprctl activeworkspace -j | jaq -r '.id'
        elif command -v swaymsg &>/dev/null; then
            swaymsg -t get_workspaces | jaq -r '.[] | select(.focused) | .num'
        else
            echo "1"
        fi
        ;;
    
    list)
        # 获取工作区列表
        if command -v niri &>/dev/null; then
            niri msg --format json workspaces | jaq -r '.[].idx' | sort -n
        elif command -v hyprctl &>/dev/null; then
            hyprctl workspaces -j | jaq -r '.[].id' | sort -n
        elif command -v swaymsg &>/dev/null; then
            swaymsg -t get_workspaces | jaq -r '.[].num' | sort -n
        else
            echo "1 2 3 4 5 6 7 8 9"
        fi
        ;;
    
    goto)
        # 切换到指定工作区
        workspace_num="$2"
        
        # 将中文数字转换为阿拉伯数字
        case "$workspace_num" in
            "一") num=1 ;;
            "二") num=2 ;;
            "三") num=3 ;;
            "四") num=4 ;;
            "五") num=5 ;;
            "六") num=6 ;;
            "七") num=7 ;;
            "八") num=8 ;;
            "九") num=9 ;;
            *) num="${workspace_num}" ;;
        esac
        
        if command -v niri &>/dev/null; then
            niri msg action focus-workspace "$num"
        elif command -v hyprctl &>/dev/null; then
            hyprctl dispatch workspace "$num"
        elif command -v swaymsg &>/dev/null; then
            swaymsg workspace number "$num"
        fi
        ;;
    
    *)
        echo "Usage: Workspace {current|list|goto <workspace>}"
        exit 1
        ;;
esac
