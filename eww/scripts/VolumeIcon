#!/bin/bash

# Volume Icon script
# Returns appropriate icon based on volume level

volume=$(../scripts/Volume --get)

if [ "$volume" = "muted" ] || [ "$volume" -eq 0 ]; then
    echo "ó°ťź"
elif [ "$volume" -lt 30 ]; then
    echo "ó°•ż"
elif [ "$volume" -lt 70 ]; then
    echo "ó°–€"
else
    echo "ó°•ľ"
fi
